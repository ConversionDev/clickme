              "type": "string"
            },
            "node": {
              "title": "Node",
              "type": "string"
            },
            "status": {
              "enum": [
                "ok",
                "error"
              ],
              "title": "Status",
              "type": "string"
            },
            "model": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
