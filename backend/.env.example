# ── backend 런타임 (시크릿 — .env로 복사해 사용, 커밋 금지) ──

# NeonDB (외부 managed) — asyncpg 드라이버
# ⚠️ Neon이 준 URL에서: postgresql:// → postgresql+asyncpg:// 로 바꾸고
#    ?sslmode=require&channel_binding=require 쿼리는 제거 (ssl/pooler는 코드 connect_args에서 자동 처리).
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/dbname

# JWT / OAuth2
JWT_SECRET=change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (프론트 origin, JSON 배열)
CORS_ORIGINS=["http://localhost:3000"]

# Multi-LLM (Track B) — 로컬만, EC2는 IAM 롤로 AWS
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=clickme

# Storage — local(개발, AWS 불필요) | s3(프로덕션)
STORAGE_BACKEND=local
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:8000/uploads
# S3_BUCKET=
# S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com
# AWS_REGION=ap-northeast-2

# app
APP_ENV=local
LOG_LEVEL=info
