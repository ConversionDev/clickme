              "type": "object"
            },
            "signals": {
              "$ref": "#/$defs/PersonaSignals"
            },
            "reasoning": {
              "title": "Reasoning",
              "type": "string"
            },
            "confidence": {
              "maximum": 1,
              "minimum": 0,
              "title": "Confidence",
              "type": "number"
            },
            "is_outlier": {
              "default": false,
              "title": "Is Outlier",
              "type": "boolean"
            }
          },
          "required": [
            "persona_id",
            "segment",
            "persona_attributes",
            "signals",
            "reasoning",
            "confidence"
          ],
          "title": "PersonaReaction",
          "type": "object"
        },
        "PersonaSignals": {
          "properties": {
            "attention": {
              "maximum": 1,
              "minimum": 0,
              "title": "Attention",
              "type": "number"
            },
            "sentiment": {
              "maximum": 1,
              "minimum": -1,
              "title": "Sentiment",
              "type": "number"
            },
            "click_intent": {
              "title": "Click Intent",
              "type": "boolean"
            },
            "conversion_intent": {
              "title": "Conversion Intent",
              "type": "boolean"
            },
            "comprehension": {
              "maximum": 1,
              "minimum": 0,
              "title": "Comprehension",
              "type": "number"
            },
            "recall": {
              "maximum": 1,
              "minimum": 0,
              "title": "Recall",
              "type": "number"
            }
          },
          "required": [
            "attention",
            "sentiment",
            "click_intent",
            "conversion_intent",
            "comprehension",
            "recall"
          ],
          "title": "PersonaSignals",
          "type": "object"
        },
        "Prediction": {
          "properties": {
            "overall_score": {
              "maximum": 100,
              "minimum": 0,
              "title": "Overall Score",
