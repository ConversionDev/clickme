            },
            "outlier_count": {
              "title": "Outlier Count",
              "type": "integer"
            },
            "mean_attention": {
              "title": "Mean Attention",
              "type": "number"
            },
            "mean_sentiment": {
              "title": "Mean Sentiment",
              "type": "number"
            },
            "click_intent_rate": {
              "title": "Click Intent Rate",
              "type": "number"
            },
            "conversion_intent_rate": {
              "title": "Conversion Intent Rate",
              "type": "number"
            },
            "mean_comprehension": {
              "title": "Mean Comprehension",
              "type": "number"
            },
            "mean_recall": {
              "title": "Mean Recall",
              "type": "number"
            },
            "ks_similarity": {
              "description": "집단 분포 유사도(베이스라인 mock)",
              "maximum": 1,
              "minimum": 0,
              "title": "Ks Similarity",
              "type": "number"
            }
          },
          "required": [
            "sample_size",
            "outlier_count",
            "mean_attention",
            "mean_sentiment",
            "click_intent_rate",
            "conversion_intent_rate",
            "mean_comprehension",
            "mean_recall",
            "ks_similarity"
          ],
          "title": "AggregatedStats",
          "type": "object"
        },
        "CampaignObjective": {
          "enum": [
            "awareness",
            "conversion"
          ],
          "title": "CampaignObjective",
          "type": "string"
        },
        "Persona": {
          "properties": {
            "persona_id": {
              "title": "Persona Id",
              "type": "string"
            },
            "segment": {
              "title": "Segment",
              "type": "string"
            },
            "cluster_id": {
              "anyOf": [
                {
                  "type": "string"
                },
