            "attributes": {
              "additionalProperties": true,
              "title": "Attributes",
              "type": "object"
            }
          },
          "required": [
            "persona_id",
            "segment"
          ],
          "title": "Persona",
          "type": "object"
        },
        "PersonaReaction": {
