              "default": null,
              "title": "Text Content"
            },
            "image_url": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Image Url"
            },
            "name": {
              "title": "Name",
              "type": "string"
            }
          },
          "required": [
            "ad_id",
            "input_type",
            "name"
          ],
          "title": "AdInput",
          "type": "object"
        },
        "AdInputType": {
          "enum": [
            "image",
            "text",
            "video",
            "url"
          ],
          "title": "AdInputType",
          "type": "string"
        },
        "AggregatedStats": {
          "properties": {
            "sample_size": {
              "title": "Sample Size",
