{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "common",
  "definitions": {
    "ApiResponse": {
      "$defs": {
        "ErrorCode": {
          "enum": [
            "VALIDATION_ERROR",
            "UNAUTHORIZED",
            "FORBIDDEN",
            "NOT_FOUND",
            "CONFLICT",
            "INVALID_CREDENTIALS",
            "TOKEN_EXPIRED",
            "INTERNAL"
          ],
          "title": "ErrorCode",
          "type": "string"
        },
        "ErrorDetail": {
          "properties": {
            "code": {
              "$ref": "#/$defs/ErrorCode"
            },
            "message": {
              "title": "Message",
              "type": "string"
            }
          },
          "required": [
            "code",
            "message"
          ],
          "title": "ErrorDetail",
          "type": "object"
        }
      },
      "properties": {
        "success": {
          "default": true,
          "title": "Success",
          "type": "boolean"
        },
        "data": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorDetail"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "ApiResponse",
      "type": "object"
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "VALIDATION_ERROR",
        "UNAUTHORIZED",
        "FORBIDDEN",
        "NOT_FOUND",
        "CONFLICT",
        "INVALID_CREDENTIALS",
        "TOKEN_EXPIRED",
        "INTERNAL"
      ]
    }
  }
}
