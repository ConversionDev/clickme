              "title": "Top Drivers",
              "type": "array"
            },
            "top_objections": {
              "items": {
                "type": "string"
              },
              "title": "Top Objections",
              "type": "array"
            },
            "copy_suggestions": {
              "items": {
                "type": "string"
              },
              "title": "Copy Suggestions",
              "type": "array"
            },
            "cta_suggestions": {
              "items": {
                "type": "string"
              },
              "title": "Cta Suggestions",
              "type": "array"
            },
            "next_ab_test": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Next Ab Test"
            }
          },
          "title": "Recommendation",
          "type": "object"
        },
        "StepTrace": {
          "properties": {
            "run_id": {
              "format": "uuid",
