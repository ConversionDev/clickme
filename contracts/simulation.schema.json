            "verdict": {
              "title": "Verdict",
              "type": "string"
            },
            "kpi": {
              "$ref": "#/$defs/PredictionKpi"
            },
            "confidence": {
              "maximum": 1,
              "minimum": 0,
              "title": "Confidence",
              "type": "number"
            }
          },
          "required": [
            "overall_score",
            "verdict",
            "kpi",
            "confidence"
          ],
          "title": "Prediction",
          "type": "object"
        },
        "PredictionKpi": {
          "properties": {
            "attention_score": {
              "maximum": 1,
              "minimum": 0,
              "title": "Attention Score",
              "type": "number"
            },
            "sentiment_score": {
              "maximum": 1,
              "minimum": 0,
              "title": "Sentiment Score",
              "type": "number"
            },
            "click_intent_rate": {
              "maximum": 1,
              "minimum": 0,
              "title": "Click Intent Rate",
              "type": "number"
            },
            "conversion_intent_rate": {
              "maximum": 1,
              "minimum": 0,
              "title": "Conversion Intent Rate",
              "type": "number"
            },
            "comprehension_score": {
              "maximum": 1,
              "minimum": 0,
              "title": "Comprehension Score",
              "type": "number"
            },
            "recall_score": {
              "maximum": 1,
              "minimum": 0,
              "title": "Recall Score",
              "type": "number"
            }
          },
          "required": [
            "attention_score",
            "sentiment_score",
            "click_intent_rate",
            "conversion_intent_rate",
            "comprehension_score",
            "recall_score"
          ],
          "title": "PredictionKpi",
          "type": "object"
        },
        "Recommendation": {
          "properties": {
            "top_drivers": {
              "items": {
